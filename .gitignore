# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
*.egg-info/
.eggs/
dist/
build/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
.vite/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Automix app data
backend/.cache/
backend/automix.db
backend/automix.db-journal
backend/automix.db-wal
backend/automix.db-shm

# Source MP4s and rendered output (large binaries — re-add with `git add -f` if needed)
videos/
# Raw intro overlay (2.7GB BGRA) — the web-sized transcode ships in frontend/public
assets/*.avi

# Environment / secrets
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/

# Playwright MCP session artifacts
.playwright-mcp/

# Desktop packaging: fetched static tools + PyInstaller outputs (dist/ build/ above)
/bin/
*.dmg
Automix-*.tar.gz
Automix-*.zip

# OS
.DS_Store
Thumbs.db
desktop.ini

# User-uploaded title fonts (built-ins are tracked explicitly)
assets/fonts/*
!assets/fonts/BebasNeue-Regular.ttf
!assets/fonts/Cubano.ttf

# Splash video background (personal / third-party artwork) and the generated
# splash.png it bakes into — kept local only, never committed and never shipped
# in public CI builds. The splash is regenerated at build time (build-local.ps1
# + the release workflow), so a tracked copy is not needed.
assets/splash-screen-bg.mp4
packaging/splash.png
